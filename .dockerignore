# Dependencies (reinstalled inside image)
node_modules/

# TypeScript output (built inside image)
dist/

# Environment files — never bake secrets into images
.env
.env.*

# Test artifacts
coverage/
tests/
tmp_*/

# Console is its own build context
console/

# Docs and config not needed at runtime
docs/
scripts/
*.md
.gitignore
.gitleaks.toml
.github/
.claude/

# Local dev
.license-dev
backups/
*.pgdump
*.log

# Docker files themselves
docker-compose*.yml
Dockerfile*
