# ─────────────────────────────────────────────────────────────────────────────
# NestFleet Environment Variables
# Copy this file to .env and fill in values before running.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (PostgreSQL 16 + pgvector) ───────────────────────────────────────
# Local dev: use docker-compose (see docker/docker-compose.yml)
# Production: append ?sslmode=require (or sslmode=verify-full with a CA cert)
DATABASE_URL=postgresql://nestfleet:nestfleet@localhost:5434/nestfleet

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: trace | debug | info | warn | error
LOG_LEVEL=info

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# Leave empty to disable tracing (uses noop exporter)
# Local: Jaeger at localhost:4318 (see docker-compose)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=nestfleet

# ── NestFleet Cloud (update manifest — optional) ──────────────────────────────
# URL for fetching update manifests from NestFleet Cloud.
# Leave as default; only override if self-hosting the update service.
NESTFLEET_CLOUD_URL=https://cloud.nestfleet.dev

# ── LLM Provider ─────────────────────────────────────────────────────────────
# NestFleet does NOT proxy LLM calls — customer configures their own provider.
# Supported: openai | anthropic | ollama | google
LLM_PROVIDER=anthropic
LLM_API_KEY=your-api-key-here
# Standard model — used by auto_reply, knowledge_capture, and as fallback.
LLM_MODEL=claude-sonnet-4-6
# Fast model — used by triage, known_issue_match, outage_routing (tight SLOs, classification tasks).
# Omit to use LLM_MODEL for all tiers.
LLM_MODEL_FAST=claude-3-5-haiku-20241022
# Complex model — used by change_prep, pr_draft_prep (document generation, largest token budgets).
# Omit to use LLM_MODEL for all tiers.
LLM_MODEL_COMPLEX=claude-sonnet-4-6
# Optional: override base URL (for Ollama or proxies)
# LLM_BASE_URL=http://localhost:11434

# ── Embedding Provider ────────────────────────────────────────────────────────
# May differ from the LLM provider. Embeddings are used for product memory RAG.
# Supported: openai | ollama
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=your-openai-api-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# Optional: override base URL (for Ollama or proxies)
# EMBEDDING_BASE_URL=http://localhost:11434

# ── GitHub Integration (SPIKE-04) ────────────────────────────────────────────
# Personal Access Token or GitHub App installation token — used for issue + PR creation
GITHUB_TOKEN=ghp_your_token_here
#
# Webhook secret — must match the secret set in the GitHub App / repo webhook settings
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
#
# GitHub App credentials (if using App-based auth instead of PAT — optional in v1)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
#
# ── Smee (local webhook proxy for dev) ────────────────────────────────────────
# Smee forwards GitHub webhook events to your local server during development.
# 1. Install smee client:  npm install -g smee-client
# 2. Run:  smee --url https://smee.io/YOUR_CHANNEL_ID \
#               --path /webhooks/github/events/YOUR_PRODUCT_ID \
#               --port 3001
# The GitHub App webhook URL should point to your smee.io channel URL.
# No env var needed — smee runs as a separate CLI process.
#
# ── Product GitHub repo (per-product config, not global env) ──────────────────
# Set per product in the DB:  product.support_policy.github_repo = "owner/repo"
# e.g. for DocuGardener:      { "github_repo": "your-org/docugardener" }

# ── Email Channel ─────────────────────────────────────────────────────────────
# Set exactly ONE of the three options below. Priority: SMTP_HOST → Postmark → Resend.
# SMTP_FROM is required for all options — must be a verified sender address.
SMTP_FROM=support@yourdomain.com

# Option A — Generic SMTP
# SMTP_HOST=smtp.yourmailprovider.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password

# Option B — Postmark
# POSTMARK_API_KEY=your-postmark-server-token

# Option C — Resend  ← recommended for DocuGardener pilot
# RESEND_API_KEY=re_your_resend_api_key_here
# SMTP_FROM=support@docugardener.io   # must be a verified domain in Resend dashboard

# ── Telegram Channel ─────────────────────────────────────────────────────────
# Telegram Bot token (set up in fast-follow after v1 email)
TELEGRAM_BOT_TOKEN=

# ── Slack Channel (DEFERRED-12) ───────────────────────────────────────────────
# Operator alert mirroring: all operator-audience notifications (approvals,
# escalations, PR-ready, stale alerts) are mirrored to Slack alongside email.
# Per-product webhook URLs can also be set in Settings → Notifications.
#
# Option A — Incoming Webhook (recommended; bound to a specific channel)
# Get from: Slack workspace → Apps → Incoming Webhooks → Add new webhook
# SLACK_WEBHOOK_URL=<your-slack-incoming-webhook-url>
#
# Option B — Bot Token (use when you need to post to multiple channels)
# SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# SLACK_DEFAULT_CHANNEL=#ops

# ── License (SPIKE-08) ───────────────────────────────────────────────────────
# Path to the JWT license file provided at purchase (SaaS paid plans).
# Leave unset to run in community mode — all features enabled, no limits.
LICENSE_FILE_PATH=./license.jwt
# HMAC secret for license JWT verification.
# Generate: openssl rand -hex 32  — must be non-empty in production.
LICENSE_SECRET=
# SEC-M4: HMAC secret for verifying signed cloud validate responses.
# Leave unset to skip signature verification.
# Generate: openssl rand -hex 32
CLOUD_REFRESH_HMAC_SECRET=

# ── Billing (NF-PIVOT) ────────────────────────────────────────────────────────
# Set to true only after legal entity registration and Stripe account setup.
BILLING_ENABLED=false

# ── Auth (SPIKE-07) ──────────────────────────────────────────────────────────
JWT_SECRET=your-secret-here-must-be-at-least-32-characters-long
BCRYPT_ROUNDS=12

# ── Secrets encryption (SEC-02) ───────────────────────────────────────────────
# AES-256-GCM key used to encrypt API keys and credentials stored in the DB.
# Generate with: openssl rand -base64 32
# Production: inject from AWS Secrets Manager / Vault — never commit a real value.
SECRET_ENCRYPTION_KEY=

# ── Telemetry (opt-in, no PII) ────────────────────────────────────────────────
TELEMETRY_ENABLED=false

# ── Operator Console (SLICE-08) ───────────────────────────────────────────────
# Production: set to your deployed console origin, e.g. https://console.yourcompany.com
# Dev: not needed (localhost:3001 is allowed automatically)
# CONSOLE_ORIGIN=https://console.yourcompany.com

# ── SaaS Fleet Provisioning (FEAT-001) ────────────────────────────────────────
# Only set these on the main NestFleet instance (nestfleet.io).
# Leave PROVISIONING_ENABLED=false on all customer VPSes.
PROVISIONING_ENABLED=false
# Hetzner Cloud API token — create at console.hetzner.cloud → Security → API Tokens
HETZNER_API_TOKEN=
# Hetzner firewall ID — run scripts/ops/infra-setup.sh once to create and get the ID
HETZNER_FIREWALL_ID=
# Cloudflare API token — Cloudflare dashboard → My Profile → API Tokens → DNS:Edit
CLOUDFLARE_API_TOKEN=
# Cloudflare Zone ID — Cloudflare dashboard → your domain → Overview → Zone ID (right sidebar)
CLOUDFLARE_ZONE_ID=
# Base domain for customer subdomains
CUSTOMER_BASE_DOMAIN=nestfleet.io
# Ops alert email — receives provisioning failure notifications
OPS_ALERT_EMAIL=ops@nestfleet.io
# SSH public key injected into all customer VPSes (generate: ssh-keygen -t ed25519)
OPS_SSH_PUBLIC_KEY=
# Bundled LLM keys — written into each customer VPS .env at provision time
BUNDLED_LLM_API_KEY=
BUNDLED_EMBEDDING_API_KEY=
# GHCR read-only PAT for pulling images on customer VPSes (leave blank if packages are public)
GHCR_TOKEN=
# Owner console auth — comma-separated user IDs allowed to access /owner/* endpoints
OWNER_USER_IDS=

# Backup Object Storage (Hetzner S3-compatible) — optional, local-only if unset
BACKUP_S3_ENDPOINT=https://nbg1.your-objectstorage.com
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_BUCKET=nestfleet-backups
