{
  "name": "nestfleet",
  "version": "0.1.0",
  "description": "NestFleet — AI-powered product operations platform",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file .env watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:migrate": "tsx src/infra/db/migrate.ts",
    "spike:ingest": "tsx scripts/ingest-docs.ts",
    "spike:eval": "tsx tests/spike-01/run-evaluation.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.41",
    "@hono/node-server": "^1.13.7",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@types/js-yaml": "^4.0.9",
    "ai": "^6.0.191",
    "bcryptjs": "^3.0.3",
    "hono": "^4.7.5",
    "jose": "^6.2.2",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "ollama-ai-provider": "^1.2.0",
    "pg-boss": "^12.18.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "ssh2": "^1.17.0",
    "stripe": "^21.0.1",
    "ulid": "^3.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^8.0.0",
    "@types/ssh2": "^1.15.5",
    "@vitest/coverage-v8": "^3.0.9",
    "msw": "^2.12.14",
    "testcontainers": "^12.0.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^3.0.9"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "notes": {
    "otel-audit": "GHSA-q7rr-3cgh-j5r3 (Prometheus exporter crash) affects @opentelemetry/sdk-node <=0.216.0. NestFleet does not start a Prometheus metrics endpoint so this path is not reachable. Fix requires OTel ecosystem upgrade 0.57→0.217 (breaks @opentelemetry/core peer deps). Track in v0.2.0 backlog."
  }
}
